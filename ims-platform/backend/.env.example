# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/instaura_ims?retryWrites=true&w=majority

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_chars_here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Upstash Redis (BullMQ queues) ───────────────────────────────────────────
REDIS_URL=rediss://:your_password@your-host.upstash.io:6379

# ─── Resend Email ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@instaura.live

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@o000000.ingest.sentry.io/0000000

# ─── n8n Automation ───────────────────────────────────────────────────────────
N8N_BASE_URL=https://your-n8n-instance.com
N8N_WEBHOOK_SECRET=your_webhook_secret

# ─── Frontend (CORS) ─────────────────────────────────────────────────────────
CLIENT_URL=https://your-app.vercel.app

# ─── Admin Seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin3641@instaura.live
ADMIN_PASSWORD=Instaura364133
